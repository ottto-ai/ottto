{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ottto.net/schemas/collector-manifest.schema.json",
  "title": "Ottto collector manifest v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "source_id",
    "collector_id",
    "display_name",
    "operations",
    "data_source_kind",
    "default_state",
    "review_tier",
    "maturity",
    "risk_classes",
    "uploads_raw_content",
    "emits"
  ],
  "properties": {
    "schema_version": {
      "const": "collector_manifest.v1"
    },
    "source_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]{1,63}$"
    },
    "collector_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]{1,63}$"
    },
    "display_name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 80
    },
    "operations": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "detect",
          "verify",
          "repair",
          "collect_usage",
          "monitor_quota",
          "upload_snapshot",
          "diagnostics",
          "uninstall_restore"
        ]
      }
    },
    "data_source_kind": {
      "type": "string",
      "enum": [
        "local_enriched",
        "live_telemetry",
        "integration_connector",
        "cloud_billing_connector"
      ]
    },
    "default_state": {
      "type": "string",
      "enum": [
        "enabled",
        "requires_setup",
        "disabled"
      ]
    },
    "review_tier": {
      "type": "string",
      "enum": [
        "official",
        "ottto_labs",
        "reviewed_community",
        "community",
        "custom_local"
      ]
    },
    "maturity": {
      "type": "string",
      "enum": [
        "stable",
        "beta",
        "experimental",
        "undocumented_surface",
        "writes_config",
        "local_only"
      ]
    },
    "uploads_raw_content": {
      "type": "boolean"
    },
    "risk_classes": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "auth_adjacent",
          "network_calls",
          "hidden_credential_read",
          "raw_prompt_or_output"
        ]
      }
    },
    "emits": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^[a-z][a-z0-9_]{1,96}$"
      }
    }
  }
}
